# Copy this file to `.env` and adjust for your machine:  cp .env.example .env
#
# The build reads `.env` if it exists, otherwise it falls back to this file —
# so a fresh clone builds out of the box with the example content on display.

# Render the shipped example-* posts and projects.
# The public template keeps this TRUE so `npm run build` produces a working
# demo. Set it to false in your own `.env` once you've added real content and
# want the examples hidden from your live site (they behave like visible:false).
SHOW_EXAMPLES=true

# --- Comments backend (docker-compose.yml) ---------------------------------
# Only needed if you enable comments (site.config.js -> comments.enabled).
# docker compose reads these; the static build does not. Copy .env.example to
# .env and set real values (POSTGRES_PASSWORD + COMMENT_DELETE_KEY at minimum).

# Postgres credentials for the `db` container.
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change-me-in-your-.env
POSTGRES_DB=portfolio

# Key a visitor must enter to delete a comment. Choose something private.
COMMENT_DELETE_KEY=change-me-secret-delete-key

# Host port the API is published on (loopback). Point your reverse proxy's
# /api/ location here, e.g. proxy_pass http://127.0.0.1:8138;
API_PORT=8138

# Optional: CORS origin for cross-origin local dev only. Leave empty in
# production (same-origin via the reverse proxy needs no CORS).
ALLOW_ORIGIN=
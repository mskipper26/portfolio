# Copy this file to `.env` and adjust for your machine:  cp .env.example .env
#
# The build reads `.env` if it exists, otherwise it falls back to this file —
# so a fresh clone builds out of the box with the example content on display.

# Render the shipped example-* posts and projects.
# The public template keeps this TRUE so `npm run build` produces a working
# demo. Set it to false in your own `.env` once you've added real content and
# want the examples hidden from your live site (they behave like visible:false).
SHOW_EXAMPLES=true